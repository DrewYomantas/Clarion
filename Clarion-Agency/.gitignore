# Clarion-Agency .gitignore

# Environment
.env
.env.*
!.env.example

# Reports (generated output — not committed)
reports/
!reports/**/.gitkeep

# Run logs
**/run_log.jsonl

# Python
__pycache__/
*.py[cod]
*.pyo

# Virtual environments
venv/
.venv/
env/
ENV/

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Temp
*.tmp
*.bak
scratch/
tmp/
