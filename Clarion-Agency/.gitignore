# Clarion-Agency .gitignore

# -----------------------------------------------------------------------
# Environment — never commit secrets
# -----------------------------------------------------------------------
.env
.env.*
!.env.example

# -----------------------------------------------------------------------
# Reports — generated output, not committed.
# Individual .gitkeep files are force-added to preserve empty subdirs.
# See: git add -f reports/[subdir]/.gitkeep
# -----------------------------------------------------------------------
reports/**

# -----------------------------------------------------------------------
# Run logs — local runtime artifacts
# -----------------------------------------------------------------------
**/run_log.jsonl
**/escalation_log.jsonl

# -----------------------------------------------------------------------
# Python
# -----------------------------------------------------------------------
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python

# -----------------------------------------------------------------------
# Virtual environments
# -----------------------------------------------------------------------
venv/
.venv/
env/
ENV/

# -----------------------------------------------------------------------
# IDE
# -----------------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo

# -----------------------------------------------------------------------
# OS
# -----------------------------------------------------------------------
.DS_Store
.DS_Store?
Thumbs.db
ehthumbs.db

# -----------------------------------------------------------------------
# Temp / scratch
# -----------------------------------------------------------------------
*.tmp
*.bak
scratch/
tmp/
