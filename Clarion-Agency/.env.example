# =======================================================================
# Clarion Agent Office — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.
# =======================================================================

# -----------------------------------------------------------------------
# REQUIRED — OpenRouter API
# Get your key at: https://openrouter.ai/keys
# -----------------------------------------------------------------------
OPENROUTER_API_KEY=your_openrouter_api_key_here

# -----------------------------------------------------------------------
# OPTIONAL — Email escalation notifications
# Used by: python workflows/notify_escalations.py --email
#
# Requires a Gmail account with an App Password (not your login password).
# Generate one at: https://myaccount.google.com/apppasswords
# Set up 2FA first if you haven't — App Passwords require it.
# -----------------------------------------------------------------------
NOTIFICATION_EMAIL=you@gmail.com
NOTIFICATION_EMAIL_PASSWORD=your_gmail_app_password_here
